def parse_prices(texto, marca=''):
    texto = texto.replace('\xa0', ' ').strip()
    energia = None
    pot_p1 = None
    pot_p2 = None

    # 1. ENERGIA (EUR/kWh)
    # Buscar "Precio del Término energía" o similar
    if energia is None:
        m = re.search(r'(?:Precio\s+del\s+Término\s+energía|Precio\s+Energía)[^0-9]*?([\d,\.]+)\s*(?:EUR|€)', texto, re.IGNORECASE | re.DOTALL)
        if m:
            val = float(m.group(1).replace(',', '.'))
            if val < 1.0:
                energia = val

    # Fallback: Precio energía con guión
    if energia is None:
        m = re.search(r'(?:Precio\s+Energía)[^-]*?-\s*([\d,\.]+)', texto, re.IGNORECASE | re.DOTALL)
        if m:
            val = float(m.group(1).replace(',', '.'))
            if val < 1.0:
                energia = val

    # Fallback: genérico €/kWh
    if energia is None:
        m = re.search(r'([\d,\.]+)\s*(?:EUR|€)\s*/\s*kWh', texto, re.IGNORECASE)
        if m:
            val = float(m.group(1).replace(',', '.'))
            if val < 1.0:
                energia = val

    # 2. POTENCIA (EUR/kW/año)
    # Format A: "Punta 34,188; Valle 34,188" (Endesa)
    punta_match = re.search(r'Punta\s+([\d,\.]+)', texto, re.IGNORECASE)
    if punta_match:
        pot_p1 = float(punta_match.group(1).replace(',', '.'))

    valle_match = re.search(r'Valle\s+([\d,\.]+)', texto, re.IGNORECASE)
    if valle_match:
        pot_p2 = float(valle_match.group(1).replace(',', '.'))

    # Format B: "P1 = 32,94" o "P1 Punta : 30,939637"
    if pot_p1 is None:
        p1_match = re.search(r'P\s*1\s*(?:Punta)?[^:]*?(?:=|:)\s*([\d,\.]+)', texto, re.IGNORECASE)
        if p1_match:
            pot_p1 = float(p1_match.group(1).replace(',', '.'))

    if pot_p2 is None:
        p2_match = re.search(r'P\s*2\s*(?:Valle)?[^:]*?(?:=|:)\s*([\d,\.]+)', texto, re.IGNORECASE)
        if p2_match:
            pot_p2 = float(p2_match.group(1).replace(',', '.'))

    # Format C: fallback genérico
    if pot_p1 is None:
        pot_pattern = r'([\d,\.]+)\s*(?:EUR|€)\s*/\s*kW\s*/?\s*(?:año|ano)'
        pot_matches = re.findall(pot_pattern, texto, re.IGNORECASE)
        if len(pot_matches) >= 1:
            pot_p1 = float(pot_matches[0].replace(',', '.'))
        if len(pot_matches) >= 2:
            pot_p2 = float(pot_matches[1].replace(',', '.'))
        elif pot_p1 is not None:
            pot_p2 = pot_p1

    return energia, pot_p1, pot_p2

def crear_comparativa(df_actual, df_anterior, fecha_hoy):
    comparativa = []
    for _, row in df_actual.iterrows():
        empresa = row['Empresa']
        ener_actual = row['Precio energia (EUR/kWh)']
        p1_actual = row['P1 (EUR/kW/ano)']
        p2_actual = row['P2 (EUR/kW/ano)']
        fila_anterior = df_anterior[df_anterior['Empresa'] == empresa]
        if not fila_anterior.empty:
            ener_anterior = fila_anterior.iloc[0]['Precio energia (EUR/kWh)']
            p1_anterior = fila_anterior.iloc[0]['P1 (EUR/kW/ano)']
            p2_anterior = fila_anterior.iloc[0]['P2 (EUR/kW/ano)']
            ener_diff = ener_actual - ener_anterior if (ener_actual and ener_anterior) else None
            ener_pct = (ener_diff / ener_anterior * 100) if (ener_actual and ener_anterior and ener_anterior != 0) else None
            p1_diff = p1_actual - p1_anterior if (p1_actual and p1_anterior) else None
            p1_pct = (p1_diff / p1_anterior * 100) if (p1_actual and p1_anterior and p1_anterior != 0) else None
            p2_diff = p2_actual - p2_anterior if (p2_actual and p2_anterior) else None
            p2_pct = (p2_diff / p2_anterior * 100) if (p2_actual and p2_anterior and p2_anterior != 0) else None
            comparativa.append({
                'Empresa': empresa,
                'Energia Actual': ener_actual,
                'Energia Anterior': ener_anterior,
                'Energia Dif': ener_diff,
                'Energia Cambio %': ener_pct,
                'P1 Actual': p1_actual,
                'P1 Anterior': p1_anterior,
                'P1 Dif': p1_diff,
                'P1 Cambio %': p1_pct,
                'P2 Actual': p2_actual,
                'P2 Anterior': p2_anterior,
                'P2 Dif': p2_diff,
                'P2 Cambio %': p2_pct,
            })
    return pd.DataFrame(comparativa)

def run():
    print("\nCNMC Benchmark Energia\n" + "="*50)
    params = build_params()
    try:
        r = requests.get(f'{BASE_URL}/ofertas/electricidad', params=params, headers=HEADERS, timeout=30)
        r.raise_for_status()
        ofertas = r.json().get('resultadoComparador', [])
    except Exception as e:
        print(f"Error API: {e}")
        return
    print(f"Ofertas totales: {len(ofertas)}\n")
    by_brand = {}
    for legal_name, config in TARGET_OFFERS.items():
        brand = config['brand']
        search_str = config['search']
        empresa_ofertas = [
            o for o in ofertas
            if o.get('tienePrecioUnico') == 'S' and
            legal_name in o.get('comercializadora', '').upper()
        ]
        if not empresa_ofertas:
            print(f"X {brand}")
            continue
        oferta = None
        for o in empresa_ofertas:
            if search_str.lower() in o.get('oferta', '').lower():
                oferta = o
                break
        oferta = oferta or empresa_ofertas[0]
        by_brand[brand] = oferta
        print(f"OK {brand}")
    print(f"\nExtrayendo {len(by_brand)} empresas...\n")
    registros = []
    for marca in sorted(by_brand.keys()):
        oferta = by_brand[marca]
        try:
            p = {**params, 'idOferta': oferta['id']}
            r = requests.get(f'{BASE_URL}/oferta', params=p, headers=HEADERS, timeout=30)
            r.raise_for_status()
            detalle = r.json()
            caract = detalle.get('caracteristicas', {})
            texto = caract.get('caracteristicas', '') if isinstance(caract, dict) else str(caract)
            energia, pot_p1, pot_p2 = parse_prices(texto, marca)
            print(f"  {marca:20} E:{str(energia)[:8] if energia else 'N/A':10} P1:{str(pot_p1)[:8] if pot_p1 else 'N/A':10} P2:{str(pot_p2)[:8] if pot_p2 else 'N/A':10}")
        except Exception as e:
            energia = pot_p1 = pot_p2 = None
            print(f"  {marca:20} ERROR: {str(e)[:30]}")
        registros.append({
            'Empresa': marca,
            'Precio energia (EUR/kWh)': energia,
            'P1 (EUR/kW/ano)': pot_p1,
            'P2 (EUR/kW/ano)': pot_p2,
        })
        time.sleep(0.15)
    df = pd.DataFrame(registros)
    out = Path('Analisis_Energia_CNMC.xlsx')
    fecha_hoy = datetime.now().strftime('%Y-%m-%d')
    if out.exists():
        from openpyxl import load_workbook
        wb = load_workbook(out)
        if fecha_hoy not in wb.sheetnames:
            ws = wb.create_sheet(fecha_hoy)
            for col, header in enumerate(df.columns, 1):
                ws.cell(1, col).value = header
            for row, record in enumerate(df.values, 2):
                for col, value in enumerate(record, 1):
                    ws.cell(row, col).value = value
            print(f"\n✓ Pestana '{fecha_hoy}' creada")
        sheet_names = [s for s in wb.sheetnames if s not in ['Benchmark', fecha_hoy]]
        if sheet_names:
            ultima_semana = sheet_names[-1]
            ws_anterior = wb[ultima_semana]
            data_anterior = []
            for row in ws_anterior.iter_rows(min_row=2, values_only=True):
                if row[0]:
                    data_anterior.append({
                        'Empresa': row[0],
                        'Precio energia (EUR/kWh)': row[1],
                        'P1 (EUR/kW/ano)': row[2],
                        'P2 (EUR/kW/ano)': row[3],
                    })
            df_anterior = pd.DataFrame(data_anterior)
            df_comparativa = crear_comparativa(df, df_anterior, fecha_hoy)
            nombre_comparativa = f"{fecha_hoy}-Comparativa"
            if nombre_comparativa not in wb.sheetnames:
                ws_comp = wb.create_sheet(nombre_comparativa)
                for col, header in enumerate(df_comparativa.columns, 1):
                    ws_comp.cell(1, col).value = header
                for row, record in enumerate(df_comparativa.values, 2):
                    for col, value in enumerate(record, 1):
                        ws_comp.cell(row, col).value = value
                print(f"✓ Pestana '{nombre_comparativa}' creada (comparativa vs {ultima_semana})")
        wb.save(out)
        print(f"   Total pestanas: {len(wb.sheetnames)}")
    else:
        df.to_excel(out, sheet_name='Benchmark', index=False)
        print(f"\n✓ Archivo creado con pestana 'Benchmark'")

if __name__ == '__main__':
    run()
